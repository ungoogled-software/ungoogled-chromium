+std::optional<EcdsaSignature> SignDigest(
+    base::span<const uint8_t, kSecp256k1PrivateKeyBytes> private_key_bytes,
+    base::span<const uint8_t, kKeccakDigestBytes> digest) {
+  crypto::OpenSSLErrStackTracer err_tracer(FROM_HERE);
+  bssl::UniquePtr<BIGNUM> field_prime = BignumFromHex(kSecp256k1PrimeHex);
+  bssl::UniquePtr<BIGNUM> order = BignumFromHex(kSecp256k1OrderHex);
+  bssl::UniquePtr<BIGNUM> half_order(BN_new());
+  bssl::UniquePtr<BIGNUM> private_key(
+      BN_bin2bn(private_key_bytes.data(), private_key_bytes.size(), nullptr));
+  bssl::UniquePtr<BIGNUM> z(BN_bin2bn(digest.data(), digest.size(), nullptr));
+  bssl::UniquePtr<BN_CTX> ctx(BN_CTX_new());
+  Secp256k1Point generator;
+  if (!field_prime || !order || !half_order || !private_key || !z || !ctx ||
+      !SetGeneratorPoint(&generator) || !BN_rshift1(half_order.get(), order.get()) ||
+      BN_is_zero(private_key.get()) || BN_cmp(private_key.get(), order.get()) >= 0) {
+    return std::nullopt;
+  }
+
+  for (size_t attempt = 0; attempt < 100; ++attempt) {
+    std::array<uint8_t, kSecp256k1PrivateKeyBytes> nonce_bytes;
+    crypto::RandBytes(nonce_bytes);
+    bssl::UniquePtr<BIGNUM> nonce(
+        BN_bin2bn(nonce_bytes.data(), nonce_bytes.size(), nullptr));
+    if (!nonce || BN_is_zero(nonce.get()) ||
+        BN_cmp(nonce.get(), order.get()) >= 0) {
+      continue;
+    }
+
+    Secp256k1Point nonce_point;
+    if (!ScalarMultiply(nonce.get(), generator, field_prime.get(), ctx.get(),
+                        &nonce_point) ||
+        BN_cmp(nonce_point.x.get(), order.get()) >= 0) {
+      continue;
+    }
+
+    bssl::UniquePtr<BIGNUM> r(BN_dup(nonce_point.x.get()));
+    bssl::UniquePtr<BIGNUM> k_inverse(BN_new());
+    bssl::UniquePtr<BIGNUM> s(BN_new());
+    bssl::UniquePtr<BIGNUM> tmp(BN_new());
+    if (!r || !k_inverse || !s || !tmp || BN_is_zero(r.get()) ||
+        !BN_mod_inverse(k_inverse.get(), nonce.get(), order.get(), ctx.get()) ||
+        !BN_mod_mul(tmp.get(), r.get(), private_key.get(), order.get(),
+                    ctx.get()) ||
+        !BN_mod_add(tmp.get(), tmp.get(), z.get(), order.get(), ctx.get()) ||
+        !BN_mod_mul(s.get(), k_inverse.get(), tmp.get(), order.get(),
+                    ctx.get()) ||
+        BN_is_zero(s.get())) {
+      continue;
+    }
+
+    uint8_t y_parity = BN_is_odd(nonce_point.y.get()) ? 1 : 0;
+    if (BN_cmp(s.get(), half_order.get()) > 0) {
+      if (!BN_sub(s.get(), order.get(), s.get())) {
+        continue;
+      }
+      y_parity ^= 1;
+    }
+
+    EcdsaSignature signature;
+    signature.y_parity = y_parity;
+    if (!BN_bn2bin_padded(signature.r.data(), signature.r.size(), r.get()) ||
+        !BN_bn2bin_padded(signature.s.data(), signature.s.size(), s.get())) {
+      continue;
+    }
+    return signature;
+  }
+  return std::nullopt;
+}
+
+void AppendRlpLength(size_t length, uint8_t offset, Bytes* out) {
+  if (length < 56) {
+    out->push_back(offset + static_cast<uint8_t>(length));
+    return;
+  }
+
+  Bytes length_bytes;
+  size_t remaining = length;
+  while (remaining > 0) {
+    length_bytes.push_back(static_cast<uint8_t>(remaining & 0xff));
+    remaining >>= 8;
+  }
+  std::ranges::reverse(length_bytes);
+  out->push_back(offset + 55 + static_cast<uint8_t>(length_bytes.size()));
+  out->insert(out->end(), length_bytes.begin(), length_bytes.end());
+}
+
+Bytes TrimLeadingZeros(base::span<const uint8_t> input) {
+  size_t first_non_zero = 0;
+  while (first_non_zero < input.size() && input[first_non_zero] == 0) {
+    ++first_non_zero;
+  }
+  return Bytes(input.begin() + first_non_zero, input.end());
+}
+
+Bytes RlpBytes(base::span<const uint8_t> input) {
+  Bytes out;
+  if (input.size() == 1 && input[0] < 0x80) {
+    out.push_back(input[0]);
+    return out;
+  }
+  AppendRlpLength(input.size(), 0x80, &out);
+  out.insert(out.end(), input.begin(), input.end());
+  return out;
+}
+
+Bytes RlpUint(uint64_t value) {
+  std::array<uint8_t, 8> bytes = {};
+  for (size_t i = 0; i < bytes.size(); ++i) {
+    bytes[bytes.size() - i - 1] = static_cast<uint8_t>(value & 0xff);
+    value >>= 8;
+  }
+  const Bytes trimmed = TrimLeadingZeros(bytes);
+  return RlpBytes(trimmed);
+}
+
+Bytes RlpList(std::vector<Bytes> items) {
+  Bytes payload;
+  for (const Bytes& item : items) {
+    payload.insert(payload.end(), item.begin(), item.end());
+  }
+
+  Bytes out;
+  AppendRlpLength(payload.size(), 0xc0, &out);
+  out.insert(out.end(), payload.begin(), payload.end());
+  return out;
+}
+
+bool HexAddressToBytes(std::string_view address,
+                       std::array<uint8_t, kEvmAddressBytes>* out) {
+  if (!base::StartsWith(address, "0x", base::CompareCase::INSENSITIVE_ASCII)) {
+    return false;
+  }
+  address.remove_prefix(2);
+  if (address.size() != kEvmAddressBytes * 2) {
+    return false;
+  }
+  std::vector<uint8_t> bytes;
+  if (!base::HexStringToBytes(address, &bytes) || bytes.size() != out->size()) {
+    return false;
+  }
+  std::ranges::copy(bytes, out->begin());
+  return true;
+}
+
+std::optional<std::array<uint8_t, 32>> DecimalAmountToUint256(
+    std::string_view amount) {
+  if (amount.empty() ||
+      !std::ranges::all_of(amount, base::IsAsciiDigit<char>)) {
+    return std::nullopt;
+  }
+  bssl::UniquePtr<BIGNUM> value = BignumFromDecimal(amount);
+  std::array<uint8_t, 32> bytes = {};
+  if (!value || !BN_bn2bin_padded(bytes.data(), bytes.size(), value.get())) {
+    return std::nullopt;
+  }
+  return bytes;
+}
+
+Bytes EncodeTip20TransferCall(const TempoChargeRequest& request) {
+  std::optional<std::array<uint8_t, 32>> amount =
+      DecimalAmountToUint256(request.amount);
+  if (!amount) {
+    return Bytes();
+  }
+
+  Bytes data(kTip20TransferSelector.begin(), kTip20TransferSelector.end());
+  data.insert(data.end(), 12, 0);
+  data.insert(data.end(), request.recipient.begin(), request.recipient.end());
+  data.insert(data.end(), amount->begin(), amount->end());
+  return data;
+}
+
+Bytes BuildTempoCalls(const TempoChargeRequest& request) {
+  Bytes transfer_data = EncodeTip20TransferCall(request);
+  if (transfer_data.empty()) {
+    return Bytes();
+  }
+
+  const Bytes call = RlpList({RlpBytes(request.currency), RlpBytes(Bytes()),
+                              RlpBytes(transfer_data)});
+  return RlpList({call});
+}
+
+Bytes BuildTempoTransaction(const TempoChargeRequest& request,
+                            base::span<const uint8_t, kTempoNonceKeyBytes>
+                                nonce_key,
+                            base::span<const uint8_t> signature) {
+  Bytes calls = BuildTempoCalls(request);
+  if (calls.empty()) {
+    return Bytes();
+  }
+
+  std::vector<Bytes> fields = {
+      RlpUint(request.chain_id),
+      RlpUint(kDefaultMaxPriorityFeePerGas),
+      RlpUint(kDefaultMaxFeePerGas),
+      RlpUint(kDefaultGasLimit),
+      calls,
+      RlpList({}),
+      RlpBytes(TrimLeadingZeros(nonce_key)),
+      RlpUint(0),
+      RlpUint(request.valid_before),
+      RlpUint(0),
+      request.fee_payer ? RlpBytes(Bytes()) : RlpBytes(request.currency),
+      request.fee_payer ? RlpBytes(Bytes({0})) : RlpBytes(Bytes()),
+      RlpList({}),
+  };
+  if (!signature.empty()) {
+    fields.push_back(RlpBytes(signature));
+  }
+
+  Bytes transaction = {kTempoTransactionType};
+  Bytes body = RlpList(std::move(fields));
+  transaction.insert(transaction.end(), body.begin(), body.end());
+  return transaction;
+}
+
+Bytes BuildTempoFeePayerEnvelope(
+    const TempoChargeRequest& request,
+    base::span<const uint8_t, kTempoNonceKeyBytes> nonce_key,
+    base::span<const uint8_t, kEvmAddressBytes> sender,
+    base::span<const uint8_t> signature) {
+  Bytes calls = BuildTempoCalls(request);
+  if (calls.empty()) {
+    return Bytes();
+  }
+
+  std::vector<Bytes> fields = {
+      RlpUint(request.chain_id),
+      RlpUint(kDefaultMaxPriorityFeePerGas),
+      RlpUint(kDefaultMaxFeePerGas),
+      RlpUint(kDefaultGasLimit),
+      calls,
+      RlpList({}),
+      RlpBytes(TrimLeadingZeros(nonce_key)),
+      RlpUint(0),
+      RlpUint(request.valid_before),
+      RlpUint(0),
+      RlpBytes(Bytes()),
+      RlpBytes(sender),
+      RlpList({}),
+      RlpBytes(signature),
+  };
+
+  Bytes envelope = {kTempoFeePayerEnvelopeType};
+  Bytes body = RlpList(std::move(fields));
+  envelope.insert(envelope.end(), body.begin(), body.end());
+  return envelope;
+}
+
+uint64_t FeePayerValidBefore() {
+  return static_cast<uint64_t>(base::Time::Now().ToTimeT()) +
+         kFeePayerValidBeforeSeconds;
+}
+
+std::optional<std::string> BuildSignedTempoTransaction(
+    const TempoChargeRequest& request,
+    base::span<const uint8_t, kSecp256k1PrivateKeyBytes> private_key_bytes,
+    std::string_view sender_address) {
+  TempoChargeRequest transaction_request = request;
+  std::array<uint8_t, kTempoNonceKeyBytes> nonce_key;
+  if (request.fee_payer) {
+    nonce_key.fill(0xff);
+    transaction_request.valid_before = FeePayerValidBefore();
+  } else {
+    crypto::RandBytes(nonce_key);
+  }
+
+  Bytes presign_transaction =
+      BuildTempoTransaction(transaction_request, nonce_key,
+                            base::span<uint8_t>());
+  if (presign_transaction.empty()) {
+    return std::nullopt;
+  }
+  const auto digest = Keccak256(presign_transaction);
+  std::optional<EcdsaSignature> signature = SignDigest(private_key_bytes, digest);
+  if (!signature) {
+    return std::nullopt;
+  }
+
+  Bytes signature_bytes;
+  signature_bytes.insert(signature_bytes.end(), signature->r.begin(),
+                         signature->r.end());
+  signature_bytes.insert(signature_bytes.end(), signature->s.begin(),
+                         signature->s.end());
+  signature_bytes.push_back(signature->y_parity);
+
+  Bytes transaction;
+  if (request.fee_payer) {
+    std::array<uint8_t, kEvmAddressBytes> sender;
+    if (!HexAddressToBytes(sender_address, &sender)) {
+      return std::nullopt;
+    }
+    transaction = BuildTempoFeePayerEnvelope(transaction_request, nonce_key,
+                                            sender, signature_bytes);
+  } else {
+    transaction =
+        BuildTempoTransaction(transaction_request, nonce_key, signature_bytes);
+  }
+  if (transaction.empty()) {
+    return std::nullopt;
+  }
+  return "0x" + base::HexEncodeLower(transaction);
+}
+
+std::optional<std::string> BuildProofSignature(
+    const PaymentChallenge& challenge,
+    uint64_t chain_id,
+    base::span<const uint8_t, kSecp256k1PrivateKeyBytes> private_key_bytes) {
+  static constexpr char kDomainType[] =
+      "EIP712Domain(string name,string version,uint256 chainId)";
+  static constexpr char kProofType[] = "Proof(string challengeId)";
+  static constexpr char kDomainName[] = "MPP";
+  static constexpr char kDomainVersion[] = "1";
+
+  std::array<uint8_t, 32> encoded_chain_id = {};
+  for (size_t i = 0; i < 8; ++i) {
+    encoded_chain_id[encoded_chain_id.size() - i - 1] =
+        static_cast<uint8_t>(chain_id & 0xff);
+    chain_id >>= 8;
+  }
+
+  Bytes domain_data;
+  const auto domain_type_hash =
+      Keccak256(base::as_byte_span(std::string_view(kDomainType)));
+  const auto name_hash =
+      Keccak256(base::as_byte_span(std::string_view(kDomainName)));
+  const auto version_hash =
+      Keccak256(base::as_byte_span(std::string_view(kDomainVersion)));
+  domain_data.insert(domain_data.end(), domain_type_hash.begin(),
+                     domain_type_hash.end());
+  domain_data.insert(domain_data.end(), name_hash.begin(), name_hash.end());
+  domain_data.insert(domain_data.end(), version_hash.begin(),
+                     version_hash.end());
+  domain_data.insert(domain_data.end(), encoded_chain_id.begin(),
+                     encoded_chain_id.end());
+  const auto domain_separator = Keccak256(domain_data);
+
+  Bytes proof_data;
+  const auto proof_type_hash =
+      Keccak256(base::as_byte_span(std::string_view(kProofType)));
+  const auto challenge_hash = Keccak256(base::as_byte_span(challenge.id));
+  proof_data.insert(proof_data.end(), proof_type_hash.begin(),
+                    proof_type_hash.end());
+  proof_data.insert(proof_data.end(), challenge_hash.begin(),
+                    challenge_hash.end());
+  const auto struct_hash = Keccak256(proof_data);
+
+  Bytes typed_data = {0x19, 0x01};
+  typed_data.insert(typed_data.end(), domain_separator.begin(),
+                    domain_separator.end());
+  typed_data.insert(typed_data.end(), struct_hash.begin(), struct_hash.end());
+  const auto digest = Keccak256(typed_data);
+  std::optional<EcdsaSignature> signature = SignDigest(private_key_bytes, digest);
+  if (!signature) {
+    return std::nullopt;
+  }
+
+  Bytes signature_bytes;
+  signature_bytes.insert(signature_bytes.end(), signature->r.begin(),
+                         signature->r.end());
+  signature_bytes.insert(signature_bytes.end(), signature->s.begin(),
+                         signature->s.end());
+  signature_bytes.push_back(signature->y_parity);
+  return "0x" + base::HexEncodeLower(signature_bytes);
+}
+
+std::optional<TempoChargeRequest> DecodeTempoChargeRequest(
+    const PaymentChallenge& challenge) {
+  std::string request_json;
+  if (!base::Base64UrlDecode(challenge.request,
+                             base::Base64UrlDecodePolicy::DISALLOW_PADDING,
+                             &request_json)) {
+    return std::nullopt;
+  }
+
+  std::optional<base::DictValue> request =
+      base::JSONReader::ReadDict(request_json, base::JSON_PARSE_RFC);
+  if (!request) {
+    return std::nullopt;
+  }
+
+  const std::string* amount = request->FindString("amount");
+  const std::string* currency = request->FindString("currency");
+  const std::string* recipient = request->FindString("recipient");
+  if (!amount || !currency || !recipient ||
+      !DecimalAmountToUint256(*amount)) {
+    return std::nullopt;
+  }
+
+  TempoChargeRequest result;
+  result.amount = *amount;
+  if (!HexAddressToBytes(*currency, &result.currency) ||
+      !HexAddressToBytes(*recipient, &result.recipient)) {
+    return std::nullopt;
+  }
+
+  if (challenge.expires) {
+    base::Time expires;
+    if (!base::Time::FromUTCString(challenge.expires->c_str(), &expires) ||
+        expires <= base::Time::Now()) {
+      return std::nullopt;
+    }
+    result.valid_before = static_cast<uint64_t>(expires.ToTimeT());
+  }
+
+  const base::DictValue* method_details = request->FindDict("methodDetails");
+  if (!method_details) {
+    return result;
+  }
+  if (std::optional<int> chain_id = method_details->FindInt("chainId");
+      chain_id && *chain_id > 0) {
+    result.chain_id = static_cast<uint64_t>(*chain_id);
+  }
+  result.fee_payer = method_details->FindBool("feePayer").value_or(false);
+  if (const base::ListValue* supported_modes =
+          method_details->FindList("supportedModes")) {
+    result.supports_pull = false;
+    for (const base::Value& value : *supported_modes) {
+      if (value.is_string() && value.GetString() == "pull") {
+        result.supports_pull = true;
+        break;
+      }
+    }
+  }
+  return result;
+}
+
+bool IsExpired(const PaymentChallenge& challenge) {
+  if (!challenge.expires) {
+    return false;
+  }
+  base::Time expires;
+  if (!base::Time::FromUTCString(challenge.expires->c_str(), &expires)) {
+    return true;
+  }
+  return expires <= base::Time::Now();
+}
+
+std::string MakeSourceDid(uint64_t chain_id, std::string_view address) {
+  return "did:pkh:eip155:" + base::NumberToString(chain_id) + ":" +
+         std::string(address);
+}
+
+void AddChallengeFieldIfPresent(base::DictValue* dict,
+                                std::string_view key,
+                                const std::optional<std::string>& value) {
+  if (value) {
+    dict->Set(key, *value);
+  }
+}
+
+std::string CreateCredentialHeader(const PaymentChallenge& challenge,
+                                   std::string_view source,
+                                   base::DictValue payload) {
+  base::DictValue challenge_dict;
+  challenge_dict.Set("id", challenge.id);
+  challenge_dict.Set("realm", challenge.realm);
+  challenge_dict.Set("method", challenge.method);
+  challenge_dict.Set("intent", challenge.intent);
+  challenge_dict.Set("request", challenge.request);
+  AddChallengeFieldIfPresent(&challenge_dict, "description",
+                             challenge.description);
+  AddChallengeFieldIfPresent(&challenge_dict, "digest", challenge.digest);
+  AddChallengeFieldIfPresent(&challenge_dict, "expires", challenge.expires);
+  AddChallengeFieldIfPresent(&challenge_dict, "opaque", challenge.opaque);
+
+  base::DictValue credential;
+  credential.Set("challenge", std::move(challenge_dict));
+  credential.Set("payload", std::move(payload));
+  credential.Set("source", source);
+
+  std::string json;
+  if (!base::JSONWriter::Write(credential, &json)) {
+    return std::string();
+  }
+  std::string encoded;
+  base::Base64UrlEncode(json, base::Base64UrlEncodePolicy::OMIT_PADDING,
+                        &encoded);
+  return "Payment " + encoded;
+}
+
+bool IsTokenChar(char c) {
+  return base::IsAsciiAlpha(c) || base::IsAsciiDigit(c) || c == '!' ||
+         c == '#' || c == '$' || c == '%' || c == '&' || c == '\'' ||
+         c == '*' || c == '+' || c == '-' || c == '.' || c == '^' ||
+         c == '_' || c == '`' || c == '|' || c == '~';
+}
+
+void SkipWhitespaceAndCommas(std::string_view input, size_t* index) {
+  while (*index < input.size() &&
+         (base::IsAsciiWhitespace(input[*index]) || input[*index] == ',')) {
+    ++*index;
+  }
+}
+
+std::map<std::string, std::string> ParseAuthParams(std::string_view input) {
+  std::map<std::string, std::string> params;
+  size_t index = 0;
+  while (index < input.size()) {
+    SkipWhitespaceAndCommas(input, &index);
+    const size_t key_start = index;
+    while (index < input.size() && IsTokenChar(input[index])) {
+      ++index;
+    }
+    if (key_start == index) {
+      break;
+    }
+    std::string key =
+        base::ToLowerASCII(input.substr(key_start, index - key_start));
+    while (index < input.size() && base::IsAsciiWhitespace(input[index])) {
+      ++index;
+    }
+    if (index >= input.size() || input[index] != '=') {
+      break;
+    }
+    ++index;
+    while (index < input.size() && base::IsAsciiWhitespace(input[index])) {
+      ++index;
+    }
+
+    std::string value;
+    if (index < input.size() && input[index] == '"') {
+      ++index;
+      while (index < input.size()) {
+        const char c = input[index++];
+        if (c == '"') {
+          break;
+        }
+        if (c == '\\' && index < input.size()) {
+          value.push_back(input[index++]);
+        } else {
+          value.push_back(c);
+        }
+      }
+    } else {
+      const size_t value_start = index;
+      while (index < input.size() && input[index] != ',') {
+        ++index;
+      }
+      value = std::string(base::TrimWhitespaceASCII(
+          input.substr(value_start, index - value_start), base::TRIM_ALL));
+    }
+    params.emplace(std::move(key), std::move(value));
+  }
+  return params;
+}
+
+std::optional<std::string> FindParam(
+    const std::map<std::string, std::string>& params,
+    std::string_view key) {
+  auto it = params.find(std::string(key));
+  if (it == params.end() || it->second.empty()) {
+    return std::nullopt;
+  }
+  return it->second;
+}
+
+}  // namespace
+
+std::optional<PaymentChallenge> ParsePaymentChallenge(
+    std::string_view header_value) {
+  header_value = base::TrimWhitespaceASCII(header_value, base::TRIM_ALL);
+  if (!base::StartsWith(header_value, "Payment",
+                        base::CompareCase::INSENSITIVE_ASCII)) {
+    return std::nullopt;
+  }
+  header_value.remove_prefix(std::string_view("Payment").size());
+  if (!header_value.empty() &&
+      !base::IsAsciiWhitespace(header_value.front())) {
+    return std::nullopt;
+  }
+
+  const auto params = ParseAuthParams(header_value);
+  std::optional<std::string> id = FindParam(params, "id");
+  std::optional<std::string> realm = FindParam(params, "realm");
+  std::optional<std::string> method = FindParam(params, "method");
+  std::optional<std::string> intent = FindParam(params, "intent");
+  std::optional<std::string> request = FindParam(params, "request");
+  if (!id || !realm || !method || !intent || !request) {
+    return std::nullopt;
+  }
+
+  PaymentChallenge challenge;
+  challenge.id = std::move(*id);
+  challenge.realm = std::move(*realm);
+  challenge.method = std::move(*method);
+  challenge.intent = std::move(*intent);
+  challenge.request = std::move(*request);
+  challenge.description = FindParam(params, "description");
+  challenge.digest = FindParam(params, "digest");
+  challenge.expires = FindParam(params, "expires");
+  challenge.opaque = FindParam(params, "opaque");
+  return challenge;
+}
+
+std::optional<TempoChargeDetails> GetTempoChargeDetails(
+    const PaymentChallenge& challenge) {
+  if (challenge.method != kTempoMethod || challenge.intent != kChargeIntent ||
+      IsExpired(challenge)) {
+    return std::nullopt;
+  }
+
+  std::optional<TempoChargeRequest> request = DecodeTempoChargeRequest(challenge);
+  if (!request || !request->supports_pull) {
+    return std::nullopt;
+  }
+
+  TempoChargeDetails details;
+  details.amount = request->amount;
+  details.currency = EvmAddressBytesToString(request->currency);
+  details.recipient = EvmAddressBytesToString(request->recipient);
+  details.chain_id = request->chain_id;
+  return details;
+}
+
+std::optional<std::string> CreateTempoChargeCredential(
+    const PaymentChallenge& challenge,
+    base::span<const uint8_t> private_key_bytes) {
+  if (private_key_bytes.size() != kSecp256k1PrivateKeyBytes ||
+      challenge.method != kTempoMethod || challenge.intent != kChargeIntent ||
+      IsExpired(challenge)) {
+    return std::nullopt;
+  }
+
+  const auto private_key_span =
+      private_key_bytes.to_fixed_extent<kSecp256k1PrivateKeyBytes>();
+  if (!private_key_span) {
+    return std::nullopt;
+  }
+  std::optional<TempoChargeRequest> request = DecodeTempoChargeRequest(challenge);
+  if (!request || !request->supports_pull) {
+    return std::nullopt;
+  }
+
+  std::array<uint8_t, kSecp256k1UncompressedPublicKeyBytes> public_key = {};
+  if (!PublicKeyFromPrivateKey(*private_key_span, &public_key)) {
+    return std::nullopt;
+  }
+  const std::string address = EvmAddressFromPublicKey(public_key);
+  if (address.empty()) {
+    return std::nullopt;
+  }
+
+  base::DictValue payload;
+  if (request->amount == "0") {
+    std::optional<std::string> signature =
+        BuildProofSignature(challenge, request->chain_id, *private_key_span);
+    if (!signature) {
+      return std::nullopt;
+    }
+    payload.Set("type", "proof");
+    payload.Set("signature", *signature);
+  } else {
+    std::optional<std::string> transaction =
+        BuildSignedTempoTransaction(*request, *private_key_span, address);
+    if (!transaction) {
+      return std::nullopt;
+    }
+    payload.Set("type", "transaction");
+    payload.Set("signature", *transaction);
+  }
+
+  std::string header = CreateCredentialHeader(
+      challenge, MakeSourceDid(request->chain_id, address), std::move(payload));
+  if (header.empty()) {
+    return std::nullopt;
+  }
+  return header;
+}
