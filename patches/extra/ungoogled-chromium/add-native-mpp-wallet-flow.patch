+MppTabHelper::MppTabHelper(content::WebContents* web_contents)
+    : content::WebContentsObserver(web_contents),
+      content::WebContentsUserData<MppTabHelper>(*web_contents) {}
+
+MppTabHelper::~MppTabHelper() = default;
