+
+export interface MppWalletsBrowserProxy {
+  getWallets(): Promise<MppWallet[]>;
+  createWallet(): Promise<boolean>;
+  removeWallet(walletId: string): Promise<boolean>;
+}
+
+export class MppWalletsBrowserProxyImpl implements MppWalletsBrowserProxy {
+  getWallets(): Promise<MppWallet[]> {
+    return sendWithPromise('getMppWallets');
+  }
+
+  createWallet(): Promise<boolean> {
+    return sendWithPromise('createMppWallet');
+  }
+
+  removeWallet(walletId: string): Promise<boolean> {
+    return sendWithPromise('removeMppWallet', walletId);
+  }
+
+  static getInstance(): MppWalletsBrowserProxy {
+    return instance || (instance = new MppWalletsBrowserProxyImpl());
+  }
+
+  static setInstance(obj: MppWalletsBrowserProxy) {
+    instance = obj;
+  }
+}
+
+let instance: MppWalletsBrowserProxy|null = null;
