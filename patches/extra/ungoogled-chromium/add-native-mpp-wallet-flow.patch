+uint64_t RotateLeft64(uint64_t value, int shift) {
+  if (shift == 0) {
+    return value;
+  }
+  return (value << shift) | (value >> (64 - shift));
+}
+
+uint64_t Load64LittleEndian(base::span<const uint8_t> input) {
+  uint64_t result = 0;
+  for (size_t i = 0; i < 8; ++i) {
+    result |= static_cast<uint64_t>(input[i]) << (8 * i);
+  }
+  return result;
+}
+
+void Store64LittleEndian(uint64_t value, base::span<uint8_t> output) {
+  for (size_t i = 0; i < 8; ++i) {
+    output[i] = static_cast<uint8_t>((value >> (8 * i)) & 0xff);
+  }
+}
