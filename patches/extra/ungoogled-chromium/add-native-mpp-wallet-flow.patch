+// static
+void MppTabHelper::RegisterProfilePrefs(PrefRegistrySimple* registry) {
+  registry->RegisterListPref(kMppWalletsPref);
+  registry->RegisterStringPref(kMppLastSelectedWalletIdPref, std::string());
+}
+
+void MppTabHelper::DidFinishNavigation(
+    content::NavigationHandle* navigation_handle) {
+  if (!navigation_handle->IsInPrimaryMainFrame() ||
+      navigation_handle->IsSameDocument() ||
+      !navigation_handle->HasCommitted() ||
+      navigation_handle->GetNetErrorCode() != net::OK) {
+    return;
+  }
+
+  const net::HttpResponseHeaders* headers =
+      navigation_handle->GetResponseHeaders();
+  if (!headers || headers->response_code() != net::HTTP_PAYMENT_REQUIRED) {
+    return;
+  }
+  std::optional<PaymentChallenge> challenge = FindTempoChargeChallenge(*headers);
+  if (!challenge) {
+    return;
+  }
+
+  // The Payment auth draft requires TLS and recommends rejecting Payment
+  // protocol messages received over non-TLS connections.
+  if (!navigation_handle->GetURL().SchemeIsCryptographic()) {
+    return;
+  }
+
+  MaybeShowWalletPicker(navigation_handle->GetURL(), std::move(*challenge));
+}
+
+void MppTabHelper::MaybeShowWalletPicker(const GURL& request_url,
+                                         PaymentChallenge challenge) {
+  if (wallet_dialog_showing_) {
+    return;
+  }
+
+  Profile* profile =
+      Profile::FromBrowserContext(web_contents()->GetBrowserContext());
+  if (!profile || profile->IsOffTheRecord()) {
+    return;
+  }
+
+  std::optional<TempoChargeDetails> charge_details =
+      GetTempoChargeDetails(challenge);
+  if (!charge_details) {
+    return;
+  }
+
+  wallet_dialog_showing_ = true;
+  pending_request_url_ = request_url;
+  pending_challenge_ = std::move(challenge);
+  wallet_dialog_delegate_ = CreateWalletSelectionDialog(
+      request_url, *charge_details, GetWallets(profile->GetPrefs()),
+      base::BindRepeating(&MppTabHelper::OnWalletSelected,
+                          weak_factory_.GetWeakPtr()),
+      base::BindRepeating(&MppTabHelper::OpenMppWalletSettings,
+                          weak_factory_.GetWeakPtr()));
+  wallet_dialog_widget_ = constrained_window::ShowWebModalDialogViewsOwned(
+      wallet_dialog_delegate_.get(), web_contents(),
+      views::Widget::InitParams::CLIENT_OWNS_WIDGET);
+  wallet_dialog_widget_->MakeCloseSynchronous(
+      base::IgnoreArgs<views::Widget::ClosedReason>(base::BindOnce(
+          &MppTabHelper::OnWalletDialogClosed, weak_factory_.GetWeakPtr())));
+}
+
+void MppTabHelper::OnWalletSelected(const std::string& wallet_id) {
+  Profile* profile =
+      Profile::FromBrowserContext(web_contents()->GetBrowserContext());
+  if (!profile || profile->IsOffTheRecord()) {
+    return;
+  }
+
+  profile->GetPrefs()->SetString(kMppLastSelectedWalletIdPref, wallet_id);
+  if (!pending_request_url_ || !pending_challenge_) {
+    return;
+  }
+
+  std::optional<std::string> encrypted_seed =
+      GetWalletEncryptedSeed(profile->GetPrefs(), wallet_id);
+  if (!encrypted_seed) {
+    return;
+  }
+
+  os_crypt_async::OSCryptAsync* os_crypt_async =
+      g_browser_process->os_crypt_async();
+  if (!os_crypt_async) {
+    return;
+  }
+
+  os_crypt_async->GetInstance(
+      base::BindOnce(&MppTabHelper::CreateCredentialAndRetry,
+                     weak_factory_.GetWeakPtr(), *pending_request_url_,
+                     *pending_challenge_, std::move(*encrypted_seed)),
+      os_crypt_async::Encryptor::Option::kEncryptSyncCompat);
+}
+
+void MppTabHelper::CreateCredentialAndRetry(
+    const GURL& request_url,
+    PaymentChallenge challenge,
+    std::string encrypted_seed,
+    os_crypt_async::Encryptor encryptor) {
+  std::string encrypted_private_key;
+  if (!base::Base64Decode(encrypted_seed, &encrypted_private_key)) {
+    return;
+  }
+
+  std::string private_key;
+  if (!encryptor.DecryptString(encrypted_private_key, &private_key)) {
+    return;
+  }
+
+  std::optional<std::string> credential =
+      CreateTempoChargeCredential(challenge, base::as_byte_span(private_key));
+  if (!credential) {
+    return;
+  }
+
+  pending_request_url_.reset();
+  pending_challenge_.reset();
+  web_contents()->GetController().LoadURL(
+      request_url, content::Referrer(), ui::PAGE_TRANSITION_RELOAD,
+      "Authorization: " + *credential + "\n");
+}
+
+void MppTabHelper::OpenMppWalletSettings() {
+  Profile* profile =
+      Profile::FromBrowserContext(web_contents()->GetBrowserContext());
+  if (!profile || profile->IsOffTheRecord()) {
+    return;
+  }
+  chrome::ShowSettingsSubPageForProfile(profile, kMppWalletSettingsSubPage);
+}
+
+void MppTabHelper::OnWalletDialogClosed() {
+  if (!wallet_dialog_showing_) {
+    return;
+  }
+  wallet_dialog_showing_ = false;
+  wallet_dialog_widget_.reset();
+  wallet_dialog_delegate_.reset();
+}
