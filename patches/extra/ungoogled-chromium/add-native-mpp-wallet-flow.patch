+void MppWalletsHandler::HandleGetWallets(const base::ListValue& args) {
+  CHECK_EQ(1U, args.size());
+  const base::Value& callback_id = args[0];
+  AllowJavascript();
+  ResolveJavascriptCallback(callback_id,
+                            GetWalletsForSettings(profile_->GetPrefs()));
+}
+
+void MppWalletsHandler::HandleCreateWallet(const base::ListValue& args) {
+  CHECK_EQ(1U, args.size());
+  base::Value callback_id = args[0].Clone();
+  AllowJavascript();
+
+  os_crypt_async::OSCryptAsync* os_crypt_async =
+      g_browser_process->os_crypt_async();
+  if (!os_crypt_async) {
+    ResolveJavascriptCallback(callback_id, base::Value(false));
+    return;
+  }
+
+  os_crypt_async->GetInstance(
+      base::BindOnce(&MppWalletsHandler::ResolveCreateWallet,
+                     weak_factory_.GetWeakPtr(), std::move(callback_id)),
+      os_crypt_async::Encryptor::Option::kEncryptSyncCompat);
+}
+
+void MppWalletsHandler::HandleRemoveWallet(const base::ListValue& args) {
+  CHECK_EQ(2U, args.size());
+  const base::Value& callback_id = args[0];
+  const std::string& wallet_id = args[1].GetString();
+  AllowJavascript();
+  ResolveJavascriptCallback(
+      callback_id, base::Value(RemoveWallet(profile_->GetPrefs(), wallet_id)));
+}
+
+void MppWalletsHandler::ResolveCreateWallet(
+    base::Value callback_id,
+    os_crypt_async::Encryptor encryptor) {
+  if (!IsJavascriptAllowed()) {
+    return;
+  }
+  ResolveJavascriptCallback(
+      callback_id, base::Value(CreateWallet(profile_->GetPrefs(), encryptor)));
+}
