+class MppWalletSelectionView : public views::BoxLayoutView {
+ public:
+  MppWalletSelectionView(
+      const GURL& request_url,
+      const TempoChargeDetails& charge_details,
+      std::vector<WalletInfo> wallets,
+      base::RepeatingCallback<void(const std::string&)> select_wallet_callback,
+      base::RepeatingClosure open_settings_callback)
+      : select_wallet_callback_(std::move(select_wallet_callback)),
+        open_settings_callback_(std::move(open_settings_callback)) {
+    views::LayoutProvider* provider = views::LayoutProvider::Get();
+    SetOrientation(views::BoxLayout::Orientation::kVertical);
+    SetCrossAxisAlignment(views::BoxLayout::CrossAxisAlignment::kStretch);
+    SetInsideBorderInsets(provider->GetInsetsMetric(views::INSETS_DIALOG));
+    SetBetweenChildSpacing(
+        provider->GetDistanceMetric(views::DISTANCE_RELATED_CONTROL_VERTICAL));
+
+    auto* title = AddChildView(std::make_unique<views::Label>(
+        wallets.empty() ? u"Set up Machine Payments"
+                        : u"Choose a wallet for Machine Payments",
+        views::style::CONTEXT_DIALOG_TITLE, views::style::STYLE_HEADLINE_4));
+    title->SetMultiLine(true);
+    title->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+
+    std::u16string description =
+        base::UTF8ToUTF16(OriginForDisplay(request_url));
+    description += wallets.empty()
+                       ? u" requested payment using the Machine Payments "
+                         u"Protocol. Create a wallet in Settings before "
+                         u"choosing one to pay with."
+                       : u" requested payment using the Machine Payments "
+                         u"Protocol. Choose a local wallet for Machine "
+                         u"Payments.";
+    AddBodyLabel(this, std::move(description));
+
+    AddBodyLabel(this, PaymentDetailLine(u"Amount", charge_details.amount));
+    AddBodyLabel(this,
+                 PaymentDetailLine(u"Currency", charge_details.currency));
+    AddBodyLabel(this,
+                 PaymentDetailLine(u"Recipient", charge_details.recipient));
+    AddBodyLabel(this, PaymentDetailLine(
+                           u"Chain ID",
+                           base::NumberToString(charge_details.chain_id)));
+
+    auto* wallet_list = AddChildView(std::make_unique<views::BoxLayoutView>());
+    wallet_list->SetOrientation(views::BoxLayout::Orientation::kVertical);
+    wallet_list->SetCrossAxisAlignment(
+        views::BoxLayout::CrossAxisAlignment::kStretch);
+    wallet_list->AddChildView(std::make_unique<views::Separator>());
+
+    if (wallets.empty()) {
+      initial_focus_view_ =
+          wallet_list->AddChildView(std::make_unique<WebAuthnHoverButton>(
+              base::BindRepeating(&MppWalletSelectionView::OpenSettingsAndClose,
+                                  base::Unretained(this)),
+              std::make_unique<views::ImageView>(ui::ImageModel::FromVectorIcon(
+                  vector_icons::kPaymentsIcon, ui::kColorIcon,
+                  kWalletIconSize)),
+              u"Open Machine Payments settings",
+              u"Create and manage local wallets before paying",
+              std::make_unique<views::ImageView>(ui::ImageModel::FromVectorIcon(
+                  vector_icons::kSubmenuArrowChromeRefreshIcon, ui::kColorIcon,
+                  kChevronIconSize)),
+              /*enabled=*/true));
+    } else {
+      for (const WalletInfo& wallet : wallets) {
+        views::View* button = wallet_list->AddChildView(std::make_unique<
+                                                        WebAuthnHoverButton>(
+            base::BindRepeating(&MppWalletSelectionView::SelectWalletAndClose,
+                                base::Unretained(this), wallet.id),
+            std::make_unique<views::ImageView>(ui::ImageModel::FromVectorIcon(
+                vector_icons::kPaymentsIcon, ui::kColorIcon, kWalletIconSize)),
+            wallet.label, wallet.storage_label,
+            std::make_unique<views::ImageView>(ui::ImageModel::FromVectorIcon(
+                vector_icons::kSubmenuArrowChromeRefreshIcon, ui::kColorIcon,
+                kChevronIconSize)),
+            /*enabled=*/true));
+        if (!initial_focus_view_) {
+          initial_focus_view_ = button;
+        }
+      }
+    }
+    wallet_list->AddChildView(std::make_unique<views::Separator>());
+  }
+
+  MppWalletSelectionView(const MppWalletSelectionView&) = delete;
+  MppWalletSelectionView& operator=(const MppWalletSelectionView&) = delete;
+  ~MppWalletSelectionView() override = default;
+
+  views::View* initial_focus_view() { return initial_focus_view_; }
+
+ private:
+  void CloseWithReason(views::Widget::ClosedReason reason) {
+    if (views::Widget* widget = GetWidget()) {
+      widget->CloseWithReason(reason);
+    }
+  }
+
+  void OpenSettingsAndClose() {
+    open_settings_callback_.Run();
+    CloseWithReason(views::Widget::ClosedReason::kAcceptButtonClicked);
+  }
+
+  void SelectWalletAndClose(const std::string& wallet_id) {
+    select_wallet_callback_.Run(wallet_id);
+    CloseWithReason(views::Widget::ClosedReason::kAcceptButtonClicked);
+  }
+
+  raw_ptr<views::View> initial_focus_view_ = nullptr;
+  base::RepeatingCallback<void(const std::string&)> select_wallet_callback_;
+  base::RepeatingClosure open_settings_callback_;
+};
+
+std::unique_ptr<views::DialogDelegate> CreateWalletSelectionDialog(
+    const GURL& request_url,
+    const TempoChargeDetails& charge_details,
+    std::vector<WalletInfo> wallets,
+    base::RepeatingCallback<void(const std::string&)> select_wallet_callback,
+    base::RepeatingClosure open_settings_callback) {
+  auto dialog = std::make_unique<views::DialogDelegate>();
+  dialog->SetModalType(ui::mojom::ModalType::kChild);
+  dialog->SetShowTitle(false);
+  dialog->SetShowCloseButton(false);
+  dialog->SetOwnershipOfNewWidget(
+      views::Widget::InitParams::CLIENT_OWNS_WIDGET);
+  dialog->set_fixed_width(views::LayoutProvider::Get()->GetDistanceMetric(
+      views::DISTANCE_MODAL_DIALOG_PREFERRED_WIDTH));
+  dialog->SetButtons(static_cast<int>(ui::mojom::DialogButton::kCancel));
+  dialog->SetDefaultButton(static_cast<int>(ui::mojom::DialogButton::kNone));
+  dialog->SetButtonStyle(ui::mojom::DialogButton::kCancel,
+                         ui::ButtonStyle::kDefault);
+  dialog->SetButtonLabel(ui::mojom::DialogButton::kCancel, u"Cancel");
+  dialog->SetTitle(u"Machine Payments");
+
+  auto view = std::make_unique<MppWalletSelectionView>(
+      request_url, charge_details, std::move(wallets),
+      std::move(select_wallet_callback), std::move(open_settings_callback));
+  auto* view_ptr = view.get();
+  dialog->SetContentsView(std::move(view));
+  dialog->SetInitiallyFocusedView(view_ptr->initial_focus_view());
+  return dialog;
+}
