+
+uint64_t RotateLeft64(uint64_t value, int shift) {
+  if (shift == 0) {
+    return value;
+  }
+  return (value << shift) | (value >> (64 - shift));
+}
+
+uint64_t Load64LittleEndian(base::span<const uint8_t> input) {
+  uint64_t result = 0;
+  for (size_t i = 0; i < 8; ++i) {
+    result |= static_cast<uint64_t>(input[i]) << (8 * i);
+  }
+  return result;
+}
+
+void Store64LittleEndian(uint64_t value, base::span<uint8_t> output) {
+  for (size_t i = 0; i < 8; ++i) {
+    output[i] = static_cast<uint8_t>((value >> (8 * i)) & 0xff);
+  }
+}
+
+void KeccakPermutation(std::array<uint64_t, 25>& state) {
+  static constexpr std::array<uint64_t, 24> kRoundConstants = {
+      0x0000000000000001ULL, 0x0000000000008082ULL, 0x800000000000808aULL,
+      0x8000000080008000ULL, 0x000000000000808bULL, 0x0000000080000001ULL,
+      0x8000000080008081ULL, 0x8000000000008009ULL, 0x000000000000008aULL,
+      0x0000000000000088ULL, 0x0000000080008009ULL, 0x000000008000000aULL,
+      0x000000008000808bULL, 0x800000000000008bULL, 0x8000000000008089ULL,
+      0x8000000000008003ULL, 0x8000000000008002ULL, 0x8000000000000080ULL,
+      0x000000000000800aULL, 0x800000008000000aULL, 0x8000000080008081ULL,
+      0x8000000000008080ULL, 0x0000000080000001ULL, 0x8000000080008008ULL};
+  static constexpr std::array<int, 24> kRhoOffsets = {
+      1,  3,  6,  10, 15, 21, 28, 36, 45, 55, 2,  14,
+      27, 41, 56, 8,  25, 43, 62, 18, 39, 61, 20, 44};
+  static constexpr std::array<size_t, 24> kPiLane = {
+      10, 7,  11, 17, 18, 3, 5,  16, 8,  21, 24, 4,
+      15, 23, 19, 13, 12, 2, 20, 14, 22, 9,  6,  1};
+
+  std::array<uint64_t, 5> column;
+  for (size_t round = 0; round < kRoundConstants.size(); ++round) {
+    for (size_t i = 0; i < column.size(); ++i) {
+      column[i] = state[i] ^ state[i + 5] ^ state[i + 10] ^ state[i + 15] ^
+                  state[i + 20];
+    }
+    for (size_t i = 0; i < column.size(); ++i) {
+      const uint64_t theta =
+          column[(i + 4) % 5] ^ RotateLeft64(column[(i + 1) % 5], 1);
+      for (size_t lane = i; lane < state.size(); lane += 5) {
+        state[lane] ^= theta;
+      }
+    }
+
+    uint64_t current = state[1];
+    for (size_t i = 0; i < kPiLane.size(); ++i) {
+      const size_t lane = kPiLane[i];
+      const uint64_t saved = state[lane];
+      state[lane] = RotateLeft64(current, kRhoOffsets[i]);
+      current = saved;
+    }
+
+    for (size_t row = 0; row < state.size(); row += 5) {
+      for (size_t i = 0; i < column.size(); ++i) {
+        column[i] = state[row + i];
+      }
+      for (size_t i = 0; i < column.size(); ++i) {
+        state[row + i] ^= (~column[(i + 1) % 5]) & column[(i + 2) % 5];
+      }
+    }
+
+    state[0] ^= kRoundConstants[round];
+  }
+}
+
+void KeccakAbsorbBlock(base::span<const uint8_t> block,
+                       std::array<uint64_t, 25>& state) {
+  for (size_t lane = 0; lane < kKeccakRateBytes / 8; ++lane) {
+    state[lane] ^= Load64LittleEndian(block.subspan(lane * 8, size_t{8}));
+  }
+  KeccakPermutation(state);
+}
+
+std::array<uint8_t, kKeccakDigestBytes> Keccak256(
+    base::span<const uint8_t> input) {
+  // EVM addresses use legacy Keccak-256 padding, not NIST SHA3-256 padding.
+  std::array<uint64_t, 25> state = {};
+  while (input.size() >= kKeccakRateBytes) {
+    KeccakAbsorbBlock(input.first(kKeccakRateBytes), state);
+    input = input.subspan(kKeccakRateBytes);
+  }
+
+  std::array<uint8_t, kKeccakRateBytes> final_block = {};
+  for (size_t i = 0; i < input.size(); ++i) {
+    final_block[i] = input[i];
+  }
+  final_block[input.size()] = 0x01;
+  final_block[kKeccakRateBytes - 1] |= 0x80;
+  KeccakAbsorbBlock(final_block, state);
+
+  std::array<uint8_t, kKeccakDigestBytes> digest = {};
+  for (size_t lane = 0; lane < kKeccakDigestBytes / 8; ++lane) {
+    Store64LittleEndian(state[lane],
+                        base::span(digest).subspan(lane * 8, size_t{8}));
+  }
+  return digest;
+}
+
+std::string EvmAddressFromPublicKey(
+    base::span<const uint8_t> uncompressed_public_key) {
+  if (uncompressed_public_key.size() != kSecp256k1UncompressedPublicKeyBytes ||
+      uncompressed_public_key[0] != 0x04) {
+    return std::string();
+  }
+
+  const auto digest = Keccak256(uncompressed_public_key.subspan(size_t{1}));
+  return "0x" + base::HexEncodeLower(base::span(digest).subspan(
+                    kKeccakDigestBytes - kEvmAddressBytes, kEvmAddressBytes));
+}
+
+bssl::UniquePtr<BIGNUM> BignumFromHex(const char* value) {
+  BIGNUM* out = nullptr;
+  if (!BN_hex2bn(&out, value)) {
+    return nullptr;
+  }
+  return bssl::UniquePtr<BIGNUM>(out);
+}
+
+void SetPointAtInfinity(Secp256k1Point* point) {
+  point->x.reset();
+  point->y.reset();
+  point->infinity = true;
+}
+
+bool SetPoint(Secp256k1Point* point, const BIGNUM* x, const BIGNUM* y) {
+  point->x.reset(BN_dup(x));
+  point->y.reset(BN_dup(y));
+  point->infinity = false;
+  return point->x && point->y;
+}
+
+bool CopyPoint(const Secp256k1Point& source, Secp256k1Point* target) {
+  if (source.infinity) {
+    SetPointAtInfinity(target);
+    return true;
+  }
+  return SetPoint(target, source.x.get(), source.y.get());
+}
+
+bool SetGeneratorPoint(Secp256k1Point* point) {
+  point->x = BignumFromHex(kSecp256k1GeneratorXHex);
+  point->y = BignumFromHex(kSecp256k1GeneratorYHex);
+  point->infinity = false;
+  return point->x && point->y;
+}
+
+bool PointDouble(const Secp256k1Point& point,
+                 const BIGNUM* field_prime,
+                 BN_CTX* ctx,
+                 Secp256k1Point* out) {
+  if (point.infinity) {
+    SetPointAtInfinity(out);
+    return true;
+  }
+  if (BN_is_zero(point.y.get())) {
+    SetPointAtInfinity(out);
+    return true;
+  }
+
+  bssl::UniquePtr<BIGNUM> numerator(BN_new());
+  bssl::UniquePtr<BIGNUM> denominator(BN_new());
+  bssl::UniquePtr<BIGNUM> inverse(BN_new());
+  bssl::UniquePtr<BIGNUM> lambda(BN_new());
+  bssl::UniquePtr<BIGNUM> x3(BN_new());
+  bssl::UniquePtr<BIGNUM> y3(BN_new());
+  bssl::UniquePtr<BIGNUM> tmp(BN_new());
+  if (!numerator || !denominator || !inverse || !lambda || !x3 || !y3 ||
+      !tmp) {
+    return false;
+  }
+
+  if (!BN_mod_sqr(tmp.get(), point.x.get(), field_prime, ctx) ||
+      !BN_mod_add(numerator.get(), tmp.get(), tmp.get(), field_prime, ctx) ||
+      !BN_mod_add(numerator.get(), numerator.get(), tmp.get(), field_prime,
+                  ctx) ||
+      !BN_mod_add(denominator.get(), point.y.get(), point.y.get(),
+                  field_prime, ctx) ||
+      !BN_mod_inverse(inverse.get(), denominator.get(), field_prime, ctx) ||
+      !BN_mod_mul(lambda.get(), numerator.get(), inverse.get(), field_prime,
+                  ctx) ||
+      !BN_mod_sqr(x3.get(), lambda.get(), field_prime, ctx) ||
+      !BN_mod_sub(x3.get(), x3.get(), point.x.get(), field_prime, ctx) ||
+      !BN_mod_sub(x3.get(), x3.get(), point.x.get(), field_prime, ctx) ||
+      !BN_mod_sub(tmp.get(), point.x.get(), x3.get(), field_prime, ctx) ||
+      !BN_mod_mul(y3.get(), lambda.get(), tmp.get(), field_prime, ctx) ||
+      !BN_mod_sub(y3.get(), y3.get(), point.y.get(), field_prime, ctx)) {
+    return false;
+  }
+
+  return SetPoint(out, x3.get(), y3.get());
+}
+
+bool PointAdd(const Secp256k1Point& lhs,
+              const Secp256k1Point& rhs,
+              const BIGNUM* field_prime,
+              BN_CTX* ctx,
+              Secp256k1Point* out) {
+  if (lhs.infinity) {
+    return CopyPoint(rhs, out);
+  }
+  if (rhs.infinity) {
+    return CopyPoint(lhs, out);
+  }
+
+  if (BN_cmp(lhs.x.get(), rhs.x.get()) == 0) {
+    if (BN_cmp(lhs.y.get(), rhs.y.get()) == 0) {
+      return PointDouble(lhs, field_prime, ctx, out);
+    }
+    SetPointAtInfinity(out);
+    return true;
+  }
+
+  bssl::UniquePtr<BIGNUM> numerator(BN_new());
+  bssl::UniquePtr<BIGNUM> denominator(BN_new());
+  bssl::UniquePtr<BIGNUM> inverse(BN_new());
+  bssl::UniquePtr<BIGNUM> lambda(BN_new());
+  bssl::UniquePtr<BIGNUM> x3(BN_new());
+  bssl::UniquePtr<BIGNUM> y3(BN_new());
+  bssl::UniquePtr<BIGNUM> tmp(BN_new());
+  if (!numerator || !denominator || !inverse || !lambda || !x3 || !y3 ||
+      !tmp) {
+    return false;
+  }
+
+  if (!BN_mod_sub(numerator.get(), rhs.y.get(), lhs.y.get(), field_prime,
+                  ctx) ||
+      !BN_mod_sub(denominator.get(), rhs.x.get(), lhs.x.get(), field_prime,
+                  ctx) ||
+      !BN_mod_inverse(inverse.get(), denominator.get(), field_prime, ctx) ||
+      !BN_mod_mul(lambda.get(), numerator.get(), inverse.get(), field_prime,
+                  ctx) ||
+      !BN_mod_sqr(x3.get(), lambda.get(), field_prime, ctx) ||
+      !BN_mod_sub(x3.get(), x3.get(), lhs.x.get(), field_prime, ctx) ||
+      !BN_mod_sub(x3.get(), x3.get(), rhs.x.get(), field_prime, ctx) ||
+      !BN_mod_sub(tmp.get(), lhs.x.get(), x3.get(), field_prime, ctx) ||
+      !BN_mod_mul(y3.get(), lambda.get(), tmp.get(), field_prime, ctx) ||
+      !BN_mod_sub(y3.get(), y3.get(), lhs.y.get(), field_prime, ctx)) {
+    return false;
+  }
+
+  return SetPoint(out, x3.get(), y3.get());
+}
+
+bool ScalarMultiply(const BIGNUM* scalar,
+                    const Secp256k1Point& point,
+                    const BIGNUM* field_prime,
+                    BN_CTX* ctx,
+                    Secp256k1Point* out) {
+  Secp256k1Point result;
+  Secp256k1Point addend;
+  if (!CopyPoint(point, &addend)) {
+    return false;
+  }
+
+  const unsigned bits = BN_num_bits(scalar);
+  for (unsigned bit = 0; bit < bits; ++bit) {
+    if (BN_is_bit_set(scalar, bit)) {
+      Secp256k1Point sum;
+      if (!PointAdd(result, addend, field_prime, ctx, &sum)) {
+        return false;
+      }
+      result = std::move(sum);
+    }
+
+    Secp256k1Point doubled;
+    if (!PointDouble(addend, field_prime, ctx, &doubled)) {
+      return false;
+    }
+    addend = std::move(doubled);
+  }
+
+  *out = std::move(result);
+  return !out->infinity;
+}
+
+std::optional<std::array<uint8_t, kSecp256k1PrivateKeyBytes>>
+GenerateSecp256k1PrivateKey(const BIGNUM* order) {
+  for (size_t attempt = 0; attempt < 100; ++attempt) {
+    std::array<uint8_t, kSecp256k1PrivateKeyBytes> private_key_bytes;
+    crypto::RandBytes(private_key_bytes);
+    bssl::UniquePtr<BIGNUM> private_key(
+        BN_bin2bn(private_key_bytes.data(), private_key_bytes.size(), nullptr));
+    if (private_key && !BN_is_zero(private_key.get()) &&
+        BN_cmp(private_key.get(), order) < 0) {
+      return private_key_bytes;
+    }
+  }
+  return std::nullopt;
+}
+
+bool PublicKeyFromPrivateKey(
+    base::span<const uint8_t, kSecp256k1PrivateKeyBytes> private_key_bytes,
+    std::array<uint8_t, kSecp256k1UncompressedPublicKeyBytes>* public_key) {
+  crypto::OpenSSLErrStackTracer err_tracer(FROM_HERE);
+  bssl::UniquePtr<BIGNUM> field_prime = BignumFromHex(kSecp256k1PrimeHex);
+  bssl::UniquePtr<BIGNUM> order = BignumFromHex(kSecp256k1OrderHex);
+  bssl::UniquePtr<BIGNUM> private_key(
+      BN_bin2bn(private_key_bytes.data(), private_key_bytes.size(), nullptr));
+  bssl::UniquePtr<BN_CTX> ctx(BN_CTX_new());
+  Secp256k1Point generator;
+  Secp256k1Point public_point;
+  if (!field_prime || !order || !private_key || !ctx ||
+      !SetGeneratorPoint(&generator) || BN_is_zero(private_key.get()) ||
+      BN_cmp(private_key.get(), order.get()) >= 0 ||
+      !ScalarMultiply(private_key.get(), generator, field_prime.get(), ctx.get(),
+                      &public_point)) {
+    return false;
+  }
+
+  (*public_key)[0] = 0x04;
+  return BN_bn2bin_padded(public_key->data() + 1, kSecp256k1PrivateKeyBytes,
+                          public_point.x.get()) &&
+         BN_bn2bin_padded(public_key->data() + 1 + kSecp256k1PrivateKeyBytes,
+                          kSecp256k1PrivateKeyBytes, public_point.y.get());
+}
+
+std::optional<WalletKey> GenerateWalletKey() {
+  // Tempo-compatible local access keys are secp256k1 keys with EVM addresses.
+  bssl::UniquePtr<BIGNUM> order = BignumFromHex(kSecp256k1OrderHex);
+  if (!order) {
+    return std::nullopt;
+  }
+  std::optional<std::array<uint8_t, kSecp256k1PrivateKeyBytes>>
+      private_key_bytes = GenerateSecp256k1PrivateKey(order.get());
+  if (!private_key_bytes) {
+    return std::nullopt;
+  }
+  std::array<uint8_t, kSecp256k1UncompressedPublicKeyBytes> public_key = {};
+  if (!PublicKeyFromPrivateKey(*private_key_bytes, &public_key)) {
+    return std::nullopt;
+  }
+
+  std::string address = EvmAddressFromPublicKey(public_key);
+  if (address.empty()) {
+    return std::nullopt;
+  }
+
+  return WalletKey{
+      std::string(reinterpret_cast<const char*>(private_key_bytes->data()),
+                  private_key_bytes->size()),
+      std::move(address),
+  };
+}
+
+std::u16string GetWalletStorageLabel() {
+#if BUILDFLAG(IS_MAC)
+  return u"macOS Keychain";
+#elif BUILDFLAG(IS_WIN)
+  return u"Windows credential storage";
+#elif BUILDFLAG(IS_CHROMEOS)
+  return u"ChromeOS encrypted profile storage";
+#elif BUILDFLAG(IS_LINUX)
+  return u"Linux secret service";
+#else
+  return u"system credential storage";
+#endif
+}
+
+std::string GenerateRandomBytes(size_t length) {
+  std::vector<uint8_t> bytes = crypto::RandBytesAsVector(length);
+  return std::string(reinterpret_cast<const char*>(bytes.data()), bytes.size());
+}
+
+bool IsUsableWalletDict(const base::DictValue& wallet) {
+  const std::string* encrypted_seed =
+      wallet.FindString(kWalletEncryptedSeedKey);
+  return encrypted_seed && !encrypted_seed->empty();
+}
+
+std::string WalletStringForSettings(const base::DictValue& wallet,
+                                    std::string_view key,
+                                    std::string_view fallback) {
+  const std::string* value = wallet.FindString(key);
+  if (!value || value->empty()) {
+    return std::string(fallback);
+  }
+  return *value;
+}
+
+std::string WalletAddressForSettings(const base::DictValue& wallet) {
+  const std::string* address = wallet.FindString(kWalletAddressKey);
+  if (address && !address->empty()) {
+    return *address;
+  }
+  return WalletStringForSettings(wallet, kWalletKeyAddressKey, "");
+}
+
+base::ListValue GetWalletsForSettings(PrefService* prefs) {
+  base::ListValue result;
+  for (const base::Value& value : prefs->GetList(kMppWalletsPref)) {
+    if (!value.is_dict() || !IsUsableWalletDict(value.GetDict())) {
+      continue;
+    }
+    const base::DictValue& wallet = value.GetDict();
+    const std::string* id = wallet.FindString(kWalletIdKey);
+    if (!id || id->empty()) {
+      continue;
+    }
+
+    base::DictValue item;
+    item.Set("id", *id);
+    item.Set("address", WalletAddressForSettings(wallet));
+    item.Set("label", WalletStringForSettings(wallet, kWalletLabelKey,
+                                              "Machine Payments Wallet"));
+    item.Set("storageLabel",
+             WalletStringForSettings(wallet, kWalletStorageLabelKey,
+                                     "Local encrypted storage"));
+    result.Append(std::move(item));
+  }
+  return result;
+}
+
+bool CreateWallet(PrefService* prefs,
+                  const os_crypt_async::Encryptor& encryptor) {
+  if (!encryptor.IsEncryptionAvailable()) {
+    return false;
+  }
+
+  std::optional<WalletKey> wallet_key = GenerateWalletKey();
+  if (!wallet_key) {
+    return false;
+  }
+
+  std::string encrypted_private_key;
+  if (!encryptor.EncryptString(wallet_key->private_key,
+                               &encrypted_private_key)) {
+    return false;
+  }
+
+  const size_t wallet_number = prefs->GetList(kMppWalletsPref).size() + 1;
+  base::DictValue wallet;
+  wallet.Set(kWalletVersionKey, 2);
+  wallet.Set(kWalletAddressKey, wallet_key->address);
+  wallet.Set(kWalletIdKey,
+             base::Base64Encode(GenerateRandomBytes(kWalletIdBytes)));
+  wallet.Set(kWalletKeyAddressKey, wallet_key->address);
+  wallet.Set(kWalletKeyTypeKey, kSecp256k1KeyType);
+  wallet.Set(kWalletLabelKey,
+             "Machine Payments Wallet " + base::NumberToString(wallet_number));
+  wallet.Set(kWalletStorageKey, "os_crypt");
+  wallet.Set(kWalletStorageLabelKey,
+             base::UTF16ToUTF8(GetWalletStorageLabel()));
+  wallet.Set(kWalletEncryptedSeedKey,
+             base::Base64Encode(encrypted_private_key));
+
+  ScopedListPrefUpdate update(prefs, kMppWalletsPref);
+  update->Append(std::move(wallet));
+  return true;
+}
+
+bool RemoveWallet(PrefService* prefs, const std::string& wallet_id) {
+  bool removed = false;
+  {
+    ScopedListPrefUpdate update(prefs, kMppWalletsPref);
+    removed = update->EraseIf([&wallet_id](const base::Value& value) {
+      if (!value.is_dict()) {
+        return false;
+      }
+      const std::string* id = value.GetDict().FindString(kWalletIdKey);
+      return id && *id == wallet_id;
+    }) > 0;
+  }
+  if (removed && prefs->GetString(kMppLastSelectedWalletIdPref) == wallet_id) {
+    prefs->SetString(kMppLastSelectedWalletIdPref, std::string());
+  }
+  return removed;
+}
