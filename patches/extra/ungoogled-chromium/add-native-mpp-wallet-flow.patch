+import {PolymerElement} from 'chrome://resources/polymer/v3_0/polymer/polymer_bundled.min.js';
+
+import {SettingsViewMixin} from '../settings_page/settings_view_mixin.js';
+
+import type {MppWallet, MppWalletsBrowserProxy} from './mpp_wallets_browser_proxy.js';
+import {MppWalletsBrowserProxyImpl} from './mpp_wallets_browser_proxy.js';
+import {getTemplate} from './mpp_wallets_page.html.js';
+
+const SettingsMppWalletsPageElementBase =
+    SettingsViewMixin(I18nMixin(PolymerElement));
+
+export class SettingsMppWalletsPageElement extends
+    SettingsMppWalletsPageElementBase {
+  static get is() {
+    return 'settings-mpp-wallets-page';
+  }
+
+  static get template() {
+    return getTemplate();
+  }
+
+  static get properties() {
+    return {
+      wallets_: {
+        type: Array,
+        value: () => [],
+      },
+
+      creatingWallet_: {
+        type: Boolean,
+        value: false,
+      },
+
+      errorMessage_: String,
+    };
+  }
+
+  declare private wallets_: MppWallet[];
+  declare private creatingWallet_: boolean;
+  declare private errorMessage_: string;
+
+  private browserProxy_: MppWalletsBrowserProxy =
+      MppWalletsBrowserProxyImpl.getInstance();
+
+  override connectedCallback() {
+    super.connectedCallback();
+    this.loadWallets_();
+  }
+
+  private async loadWallets_() {
+    this.wallets_ = await this.browserProxy_.getWallets();
+  }
+
+  private async onCreateWalletClick_() {
+    this.creatingWallet_ = true;
+    this.errorMessage_ = '';
+    const created = await this.browserProxy_.createWallet();
+    this.creatingWallet_ = false;
+    if (!created) {
+      this.errorMessage_ = this.i18n('mppWalletCreateError');
+      return;
+    }
+    await this.loadWallets_();
+  }
+
+  private async onRemoveWalletClick_(event: PointerEvent&{
+    model: {item: MppWallet}
+  }) {
+    this.errorMessage_ = '';
+    await this.browserProxy_.removeWallet(event.model.item.id);
+    await this.loadWallets_();
+  }
+
+  private hasWallets_(wallets: MppWallet[]): boolean {
+    return wallets.length > 0;
+  }
+
+  private getRemoveWalletLabel_(walletLabel: string): string {
+    return this.i18n('mppRemoveWalletA11yLabel', walletLabel);
+  }
+
+  override focusBackButton() {
+    this.shadowRoot!.querySelector('settings-subpage')!.focusBackButton();
+  }
+}
+
+declare global {
+  interface HTMLElementTagNameMap {
+    'settings-mpp-wallets-page': SettingsMppWalletsPageElement;
+  }
+}
+
+customElements.define(
+    SettingsMppWalletsPageElement.is, SettingsMppWalletsPageElement);
