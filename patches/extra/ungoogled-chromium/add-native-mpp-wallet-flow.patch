+bool PublicKeyFromPrivateKey(
+    base::span<const uint8_t, kSecp256k1PrivateKeyBytes> private_key_bytes,
+    std::array<uint8_t, kSecp256k1UncompressedPublicKeyBytes>* public_key) {
+  bssl::UniquePtr<BIGNUM> field_prime = BignumFromHex(kSecp256k1PrimeHex);
+  bssl::UniquePtr<BIGNUM> order = BignumFromHex(kSecp256k1OrderHex);
+  bssl::UniquePtr<BIGNUM> private_key(
+      BN_bin2bn(private_key_bytes.data(), private_key_bytes.size(), nullptr));
+  bssl::UniquePtr<BN_CTX> ctx(BN_CTX_new());
+  Secp256k1Point generator;
+  Secp256k1Point public_point;
+  if (!field_prime || !order || !private_key || !ctx ||
+      !SetGeneratorPoint(&generator) || BN_is_zero(private_key.get()) ||
+      BN_cmp(private_key.get(), order.get()) >= 0 ||
+      !ScalarMultiply(private_key.get(), generator, field_prime.get(), ctx.get(),
+                      &public_point)) {
+    return false;
+  }
+
+  (*public_key)[0] = 0x04;
+  return BN_bn2bin_padded(public_key->data() + 1, kSecp256k1PrivateKeyBytes,
+                          public_point.x.get()) &&
+         BN_bn2bin_padded(public_key->data() + 1 + kSecp256k1PrivateKeyBytes,
+                          kSecp256k1PrivateKeyBytes, public_point.y.get());
+}
+
+std::string EvmAddressFromPublicKey(
+    base::span<const uint8_t> uncompressed_public_key) {
+  if (uncompressed_public_key.size() != kSecp256k1UncompressedPublicKeyBytes ||
+      uncompressed_public_key[0] != 0x04) {
+    return std::string();
+  }
+
+  const auto digest = Keccak256(uncompressed_public_key.subspan(size_t{1}));
+  const auto address = base::span(digest).subspan(
+      kKeccakDigestBytes - kEvmAddressBytes, kEvmAddressBytes);
+  return EvmAddressBytesToString(address);
+}
