+  web_ui()->RegisterMessageCallback(
+      "getMppWallets", base::BindRepeating(&MppWalletsHandler::HandleGetWallets,
+                                           base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "createMppWallet",
+      base::BindRepeating(&MppWalletsHandler::HandleCreateWallet,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "removeMppWallet",
+      base::BindRepeating(&MppWalletsHandler::HandleRemoveWallet,
+                          base::Unretained(this)));
+}
