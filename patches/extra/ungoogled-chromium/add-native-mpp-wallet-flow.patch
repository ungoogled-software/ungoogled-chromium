+void SetPointAtInfinity(Secp256k1Point* point) {
+  point->x.reset();
+  point->y.reset();
+  point->infinity = true;
+}
+
+bool SetPoint(Secp256k1Point* point, const BIGNUM* x, const BIGNUM* y) {
+  point->x.reset(BN_dup(x));
+  point->y.reset(BN_dup(y));
+  point->infinity = false;
+  return point->x && point->y;
+}
+
+bool CopyPoint(const Secp256k1Point& source, Secp256k1Point* target) {
+  if (source.infinity) {
+    SetPointAtInfinity(target);
+    return true;
+  }
+  return SetPoint(target, source.x.get(), source.y.get());
+}
+
+bool SetGeneratorPoint(Secp256k1Point* point) {
+  point->x = BignumFromHex(kSecp256k1GeneratorXHex);
+  point->y = BignumFromHex(kSecp256k1GeneratorYHex);
+  point->infinity = false;
+  return point->x && point->y;
+}
+
+bool PointDouble(const Secp256k1Point& point,
+                 const BIGNUM* field_prime,
+                 BN_CTX* ctx,
+                 Secp256k1Point* out) {
+  if (point.infinity) {
+    SetPointAtInfinity(out);
+    return true;
+  }
+  if (BN_is_zero(point.y.get())) {
+    SetPointAtInfinity(out);
+    return true;
+  }
+
+  bssl::UniquePtr<BIGNUM> numerator(BN_new());
+  bssl::UniquePtr<BIGNUM> denominator(BN_new());
+  bssl::UniquePtr<BIGNUM> inverse(BN_new());
+  bssl::UniquePtr<BIGNUM> lambda(BN_new());
+  bssl::UniquePtr<BIGNUM> x3(BN_new());
+  bssl::UniquePtr<BIGNUM> y3(BN_new());
+  bssl::UniquePtr<BIGNUM> tmp(BN_new());
+  if (!numerator || !denominator || !inverse || !lambda || !x3 || !y3 ||
+      !tmp) {
+    return false;
+  }
+
+  if (!BN_mod_sqr(tmp.get(), point.x.get(), field_prime, ctx) ||
+      !BN_mod_add(numerator.get(), tmp.get(), tmp.get(), field_prime, ctx) ||
+      !BN_mod_add(numerator.get(), numerator.get(), tmp.get(), field_prime,
+                  ctx) ||
+      !BN_mod_add(denominator.get(), point.y.get(), point.y.get(),
+                  field_prime, ctx) ||
+      !BN_mod_inverse(inverse.get(), denominator.get(), field_prime, ctx) ||
+      !BN_mod_mul(lambda.get(), numerator.get(), inverse.get(), field_prime,
+                  ctx) ||
+      !BN_mod_sqr(x3.get(), lambda.get(), field_prime, ctx) ||
+      !BN_mod_sub(x3.get(), x3.get(), point.x.get(), field_prime, ctx) ||
+      !BN_mod_sub(x3.get(), x3.get(), point.x.get(), field_prime, ctx) ||
+      !BN_mod_sub(tmp.get(), point.x.get(), x3.get(), field_prime, ctx) ||
+      !BN_mod_mul(y3.get(), lambda.get(), tmp.get(), field_prime, ctx) ||
+      !BN_mod_sub(y3.get(), y3.get(), point.y.get(), field_prime, ctx)) {
+    return false;
+  }
+
+  return SetPoint(out, x3.get(), y3.get());
+}
+
+bool PointAdd(const Secp256k1Point& lhs,
+              const Secp256k1Point& rhs,
+              const BIGNUM* field_prime,
+              BN_CTX* ctx,
+              Secp256k1Point* out) {
+  if (lhs.infinity) {
+    return CopyPoint(rhs, out);
+  }
+  if (rhs.infinity) {
+    return CopyPoint(lhs, out);
+  }
+
+  if (BN_cmp(lhs.x.get(), rhs.x.get()) == 0) {
+    if (BN_cmp(lhs.y.get(), rhs.y.get()) == 0) {
+      return PointDouble(lhs, field_prime, ctx, out);
+    }
+    SetPointAtInfinity(out);
+    return true;
+  }
+
+  bssl::UniquePtr<BIGNUM> numerator(BN_new());
+  bssl::UniquePtr<BIGNUM> denominator(BN_new());
+  bssl::UniquePtr<BIGNUM> inverse(BN_new());
+  bssl::UniquePtr<BIGNUM> lambda(BN_new());
+  bssl::UniquePtr<BIGNUM> x3(BN_new());
+  bssl::UniquePtr<BIGNUM> y3(BN_new());
+  bssl::UniquePtr<BIGNUM> tmp(BN_new());
+  if (!numerator || !denominator || !inverse || !lambda || !x3 || !y3 ||
+      !tmp) {
+    return false;
+  }
+
+  if (!BN_mod_sub(numerator.get(), rhs.y.get(), lhs.y.get(), field_prime,
+                  ctx) ||
+      !BN_mod_sub(denominator.get(), rhs.x.get(), lhs.x.get(), field_prime,
+                  ctx) ||
+      !BN_mod_inverse(inverse.get(), denominator.get(), field_prime, ctx) ||
+      !BN_mod_mul(lambda.get(), numerator.get(), inverse.get(), field_prime,
+                  ctx) ||
+      !BN_mod_sqr(x3.get(), lambda.get(), field_prime, ctx) ||
+      !BN_mod_sub(x3.get(), x3.get(), lhs.x.get(), field_prime, ctx) ||
+      !BN_mod_sub(x3.get(), x3.get(), rhs.x.get(), field_prime, ctx) ||
+      !BN_mod_sub(tmp.get(), lhs.x.get(), x3.get(), field_prime, ctx) ||
+      !BN_mod_mul(y3.get(), lambda.get(), tmp.get(), field_prime, ctx) ||
+      !BN_mod_sub(y3.get(), y3.get(), lhs.y.get(), field_prime, ctx)) {
+    return false;
+  }
+
+  return SetPoint(out, x3.get(), y3.get());
+}
+
+bool ScalarMultiply(const BIGNUM* scalar,
+                    const Secp256k1Point& point,
+                    const BIGNUM* field_prime,
+                    BN_CTX* ctx,
+                    Secp256k1Point* out) {
+  Secp256k1Point result;
+  Secp256k1Point addend;
+  if (!CopyPoint(point, &addend)) {
+    return false;
+  }
+
+  const unsigned bits = BN_num_bits(scalar);
+  for (unsigned bit = 0; bit < bits; ++bit) {
+    if (BN_is_bit_set(scalar, bit)) {
+      Secp256k1Point sum;
+      if (!PointAdd(result, addend, field_prime, ctx, &sum)) {
+        return false;
+      }
+      result = std::move(sum);
+    }
+
+    Secp256k1Point doubled;
+    if (!PointDouble(addend, field_prime, ctx, &doubled)) {
+      return false;
+    }
+    addend = std::move(doubled);
+  }
+
+  *out = std::move(result);
+  return !out->infinity;
+}
