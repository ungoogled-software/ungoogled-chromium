+constexpr char kMppLastSelectedWalletIdPref[] = "mpp.last_selected_wallet_id";
+constexpr char kMppWalletsPref[] = "mpp.wallets";
+constexpr char kWalletEncryptedSeedKey[] = "encrypted_seed";
+constexpr char kWalletIdKey[] = "id";
+constexpr char kWalletLabelKey[] = "label";
+constexpr char kWalletStorageLabelKey[] = "storage_label";
+constexpr int kWalletIconSize = 24;
+constexpr int kChevronIconSize = 20;
+constexpr char kMppWalletSettingsSubPage[] = "mppWallets";
+
+struct WalletInfo {
+  std::string id;
+  std::u16string label;
+  std::u16string storage_label;
+};
+
+std::string OriginForDisplay(const GURL& url) {
+  url::Origin origin = url::Origin::Create(url);
+  if (!origin.opaque()) {
+    return origin.Serialize();
+  }
+  return url.spec();
+}
+
+bool IsUsableWalletDict(const base::DictValue& wallet) {
+  const std::string* encrypted_seed =
+      wallet.FindString(kWalletEncryptedSeedKey);
+  return encrypted_seed && !encrypted_seed->empty();
+}
+
+std::u16string WalletStringForDisplay(const base::DictValue& wallet,
+                                      std::string_view key,
+                                      std::u16string_view fallback) {
+  const std::string* value = wallet.FindString(key);
+  if (!value || value->empty()) {
+    return std::u16string(fallback);
+  }
+  return base::UTF8ToUTF16(*value);
+}
+
+void AddBodyLabel(views::View* parent, std::u16string text) {
+  auto* label = parent->AddChildView(std::make_unique<views::Label>(
+      std::move(text), views::style::CONTEXT_DIALOG_BODY_TEXT));
+  label->SetMultiLine(true);
+  label->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+}
+
+std::u16string PaymentDetailLine(std::u16string_view label,
+                                 std::string_view value) {
+  return std::u16string(label) + u": " + base::UTF8ToUTF16(value);
+}
+
+std::vector<WalletInfo> GetWallets(PrefService* prefs) {
+  std::vector<WalletInfo> wallets;
+  const std::string last_selected_wallet_id =
+      prefs->GetString(kMppLastSelectedWalletIdPref);
+  bool prioritized_last_selected_wallet = false;
+  for (const base::Value& value : prefs->GetList(kMppWalletsPref)) {
+    if (!value.is_dict() || !IsUsableWalletDict(value.GetDict())) {
+      continue;
+    }
+    const base::DictValue& wallet = value.GetDict();
+    const std::string* id = wallet.FindString(kWalletIdKey);
+    if (!id || id->empty()) {
+      continue;
+    }
+    WalletInfo wallet_info{
+        *id,
+        WalletStringForDisplay(wallet, kWalletLabelKey,
+                               u"Machine Payments Wallet"),
+        WalletStringForDisplay(wallet, kWalletStorageLabelKey,
+                               u"Local encrypted storage"),
+    };
+    if (!prioritized_last_selected_wallet &&
+        wallet_info.id == last_selected_wallet_id) {
+      wallets.insert(wallets.begin(), std::move(wallet_info));
+      prioritized_last_selected_wallet = true;
+    } else {
+      wallets.push_back(std::move(wallet_info));
+    }
+  }
+  return wallets;
+}
+
+std::optional<PaymentChallenge> FindTempoChargeChallenge(
+    const net::HttpResponseHeaders& headers) {
+  size_t iterator = 0;
+  while (std::optional<std::string_view> value =
+             headers.EnumerateHeader(&iterator, "www-authenticate")) {
+    std::optional<PaymentChallenge> challenge = ParsePaymentChallenge(*value);
+    if (challenge && challenge->method == "tempo" &&
+        challenge->intent == "charge") {
+      return challenge;
+    }
+  }
+  return std::nullopt;
+}
+
+std::optional<std::string> GetWalletEncryptedSeed(PrefService* prefs,
+                                                  const std::string& wallet_id) {
+  for (const base::Value& value : prefs->GetList(kMppWalletsPref)) {
+    if (!value.is_dict()) {
+      continue;
+    }
+    const base::DictValue& wallet = value.GetDict();
+    const std::string* id = wallet.FindString(kWalletIdKey);
+    const std::string* encrypted_seed =
+        wallet.FindString(kWalletEncryptedSeedKey);
+    if (id && *id == wallet_id && encrypted_seed &&
+        !encrypted_seed->empty()) {
+      return *encrypted_seed;
+    }
+  }
+  return std::nullopt;
+}
