+constexpr char kSecp256k1GeneratorXHex[] =
+    "79BE667EF9DCBBAC55A06295CE870B07029BFCDB2DCE28D959F2815B16F81798";
+constexpr char kSecp256k1GeneratorYHex[] =
+    "483ADA7726A3C4655DA4FBFC0E1108A8FD17B448A68554199C47D08FFB10D4B8";
+constexpr size_t kEvmAddressBytes = 20;
+constexpr size_t kKeccakDigestBytes = 32;
+constexpr size_t kKeccakRateBytes = 136;
+constexpr size_t kSecp256k1PrivateKeyBytes = 32;
+constexpr size_t kSecp256k1UncompressedPublicKeyBytes = 65;
